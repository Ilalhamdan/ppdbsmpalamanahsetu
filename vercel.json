{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.8.0"
        }
    },
    "routes": [
        {
            "src": "/_next/static/(.*)",
            "dest": "/_next/static/$1"
        },
        {
            "src": "/(.*).(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)",
            "dest": "/public/$1.$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_STORAGE": "/tmp",
        "VIEW_COMPILED_PATH": "/tmp",
        "LOG_CHANNEL": "stderr"
    }
}
